{
  "name": "aurora-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api,worker -c cyan,magenta,yellow \"npm run dev -w @aurora/web\" \"npm run dev -w @aurora/api\" \"npm run dev -w @aurora/worker\"",
    "dev:web": "npm run dev -w @aurora/web",
    "dev:api": "npm run dev -w @aurora/api",
    "dev:worker": "npm run dev -w @aurora/worker",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate -w @aurora/database",
    "db:migrate": "npm run db:migrate -w @aurora/database",
    "db:studio": "npm run db:studio -w @aurora/database"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "playwright": "^1.60.0",
    "typescript": "^5.7.2"
  }
}
