{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@aurora/config": ["packages/config/src/index.ts"],
      "@aurora/database": ["packages/database/src/index.ts"],
      "@aurora/queues": ["packages/queues/src/index.ts"],
      "@aurora/storage": ["packages/storage/src/index.ts"],
      "@aurora/types": ["packages/types/src/index.ts"]
    }
  }
}
